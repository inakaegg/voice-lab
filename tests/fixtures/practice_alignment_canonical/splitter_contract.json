{
  "fixture_contract_version": 1,
  "alignment_contract_version": 1,
  "cases": [
    {
      "name": "zh_hard_sentence_boundaries",
      "text": "你好。请坐！谢谢？",
      "expected_phrases": ["你好。", "请坐！", "谢谢？"]
    },
    {
      "name": "zh_commas_and_colon_stay_inside_phrase",
      "text": "步骤一：打开应用，然后登录。",
      "expected_phrases": ["步骤一：打开应用，然后登录。"]
    },
    {
      "name": "mixed_semicolon_is_hard_boundary",
      "text": "先检查车票；Then enter the gate; 最后上车。",
      "expected_phrases": ["先检查车票；", "Then enter the gate;", "最后上车。"]
    },
    {
      "name": "newlines_and_empty_fragments",
      "text": "第一行\n\n第二行\r\n第三行。",
      "expected_phrases": ["第一行", "第二行", "第三行。"]
    },
    {
      "name": "email_and_title_periods_are_protected",
      "text": "Email Ms. Chen at qa@example.com. Then wait.",
      "expected_phrases": ["Email Ms. Chen at qa@example.com.", "Then wait."]
    },
    {
      "name": "url_and_version_periods_are_protected",
      "text": "Open https://example.com/v1.2/docs. Then install v2.5.1.",
      "expected_phrases": ["Open https://example.com/v1.2/docs.", "Then install v2.5.1."]
    },
    {
      "name": "decimal_period_is_protected",
      "text": "Pay 3.14 dollars. Keep 2.5 for later.",
      "expected_phrases": ["Pay 3.14 dollars.", "Keep 2.5 for later."]
    },
    {
      "name": "closing_quote_stays_with_previous_phrase",
      "text": "He said \"Go now!\" Then left.",
      "expected_phrases": ["He said \"Go now!\"", "Then left."]
    },
    {
      "name": "closing_parenthesis_stays_with_previous_phrase",
      "text": "Try again (really?). Then stop.",
      "expected_phrases": ["Try again (really?).", "Then stop."]
    },
    {
      "name": "ellipsis_does_not_split_by_itself",
      "text": "Wait... keep going. Done.",
      "expected_phrases": ["Wait... keep going.", "Done."]
    },
    {
      "name": "consecutive_terminal_marks_stay_together",
      "text": "Really?! Yes!!",
      "expected_phrases": ["Really?!", "Yes!!"]
    },
    {
      "name": "boundary_only_input_is_empty",
      "text": "  。。！？；\n  ",
      "expected_phrases": []
    }
  ]
}

# Copy this file outside git control before use, for example:
#   cp scripts/runpod.env.example .runpod.env
#
# Do not commit .runpod.env, API keys, registry passwords, or tokens.

RUNPOD_IMAGE=docker.io/dockerhub-user/mo-speech:gpu-smoke
# 差分だけ重ねて再pushしたい場合に、直前のイメージを指定する。
RUNPOD_BASE_IMAGE=
RUNPOD_POD_NAME=mo-speech-gpu-smoke
RUNPOD_ENDPOINT_NAME=mo-speech-inference
RUNPOD_SERVERLESS_TEMPLATE_NAME=mo-speech-serverless
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=
RUNPOD_SERVERLESS_TRANSLATION_BACKEND=openai
RUNPOD_SERVERLESS_REQUEST_MODE=async
RUNPOD_SERVERLESS_TIMEOUT_SECONDS=1800
RUNPOD_SERVERLESS_POLL_INTERVAL_SECONDS=1.0
RUNPOD_SERVERLESS_HEALTH_TIMEOUT_SECONDS=3

RUNPOD_GPU_ID="NVIDIA A40"
RUNPOD_GPU_COUNT=1
RUNPOD_CONTAINER_DISK_GB=60
RUNPOD_NETWORK_VOLUME_ID=
RUNPOD_VOLUME_NAME=mo-speech-models
RUNPOD_VOLUME_SIZE_GB=30
# Serverless templateではRunPod側の返却値に合わせて /workspace を使う。
# GPU Podで明示mountする場合は /runpod-volume に変えてもよい。
RUNPOD_VOLUME_MOUNT_PATH=/workspace
RUNPOD_DATA_CENTER_ID=
RUNPOD_DATA_CENTER_IDS=
RUNPOD_MIN_CUDA_VERSION=12.4
RUNPOD_PORTS=8000/http
RUNPOD_WORKERS_MIN=0
RUNPOD_IDLE_TIMEOUT_SECONDS=300
RUNPOD_FLASH_BOOT=1
RUNPOD_STOP_AFTER=4h

MO_PROVIDER_MODE=local
MO_ASR_PROVIDER=faster-whisper
MO_TRANSLATION_PROVIDER=qwen3
MO_TTS_PROVIDER=qwen-seed-vc
MO_PRELOAD_MODELS=0
MO_VC_BACKENDS=seed-vc
MO_RUNPOD_PRELOAD_ON_START=1
MO_RUNPOD_PRELOAD_VOICE_CONVERSION_ON_START=0
MO_RUNPOD_RELEASE_VOICE_CONVERSION_BEFORE_VIBEVOICE=1
MO_AUDIO_HISTORY_ENABLED=0
# ローカルFastAPIをgatewayにしてRunPod ServerlessのSeed-VCを使う場合:
# MO_VC_BACKENDS=runpod-seed-vc

# OpenAI API backendを使う場合だけ、git管理外の .runpod.env にAPIキーを入れる。
# OPENAI_API_KEY=
OPENAI_ASR_MODEL=gpt-4o-transcribe
OPENAI_TRANSLATION_MODEL=gpt-5.5
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=wav
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSLATION_SAMPLE_RATE=24000
OPENAI_REALTIME_TRANSLATION_TIMEOUT_SECONDS=90
MO_VIBEVOICE_DIRECTED_ASR_PROVIDER=openai
MO_VIBEVOICE_DIRECTED_OPENAI_ASR_MODEL=whisper-1
MO_VIBEVOICE_DIRECTED_ASR_LANGUAGE=auto
MO_VIBEVOICE_DIRECTED_VC_ENABLED=1
MO_VIBEVOICE_DIRECTED_VC_BACKEND=seed-vc
GOOGLE_TTS_TIMEOUT_SECONDS=30

MODEL_CACHE_DIR=/workspace/models
HF_HOME=/workspace/huggingface
HF_HUB_CACHE=/workspace/huggingface/hub
FASTER_WHISPER_CACHE_DIR=/workspace/models/faster-whisper
SEED_VC_WORK_DIR=/workspace/work/seed-vc

FASTER_WHISPER_MODEL=mobiuslabsgmbh/faster-whisper-large-v3-turbo
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_LOCAL_FILES_ONLY=0

QWEN_TRANSLATION_MODEL=Qwen/Qwen3-4B
QWEN_TRANSLATION_DEVICE_MAP=auto
QWEN_TRANSLATION_DTYPE=auto
QWEN_TRANSLATION_LOCAL_FILES_ONLY=0

QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_TTS_DEVICE_MAP=auto
QWEN_TTS_DTYPE=float16

SEED_VC_FP16=true
SEED_VC_EXECUTION_MODE=resident
SEED_VC_REFERENCE_MAX_SECONDS=12
SEED_VC_REFERENCE_SAMPLE_RATE=24000
SEED_VC_REFERENCE_PREPARE_TIMEOUT_SECONDS=90
SEED_VC_DIFFUSION_STEPS=8
SEED_VC_LENGTH_ADJUST=1.0
SEED_VC_INFERENCE_CFG_RATE=0.7

MO_VIBEVOICE_HOME=/workspace/models/vibevoice/huggingface/hub
COMFYUI_VIBEVOICE_PATH=/app/ComfyUI-VibeVoice
MO_VIBEVOICE_CLI=/app/src/mo_speech/vibevoice_cli.py
MO_VIBEVOICE_TIMEOUT_SECONDS=1800
VIBEVOICE_MODEL_REPO=microsoft/VibeVoice-1.5B
VIBEVOICE_MODEL_REVISION=1904eae38036e9c780d28e27990c27748984eafe
VIBEVOICE_TOKENIZER_REPO=Qwen/Qwen2.5-1.5B
VIBEVOICE_TOKENIZER_REVISION=8faed761d45a263340a0528343f099c05c9a4323

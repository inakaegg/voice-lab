# Copy this file outside git control before use, for example:
#   cp scripts/runpod.env.example .runpod.env
#
# Do not commit .runpod.env, API keys, registry passwords, or tokens.

RUNPOD_IMAGE=docker.io/dockerhub-user/mo-speech:gpu-smoke
# 差分だけ重ねて再pushしたい場合に、直前のイメージを指定する。
RUNPOD_BASE_IMAGE=
RUNPOD_POD_NAME=mo-speech-gpu-smoke
RUNPOD_ENDPOINT_NAME=mo-speech-inference
RUNPOD_SERVERLESS_TEMPLATE_NAME=mo-speech-serverless

RUNPOD_GPU_ID="NVIDIA A40"
RUNPOD_GPU_COUNT=1
RUNPOD_CONTAINER_DISK_GB=60
RUNPOD_NETWORK_VOLUME_ID=
RUNPOD_VOLUME_NAME=mo-speech-models
RUNPOD_VOLUME_SIZE_GB=120
RUNPOD_VOLUME_MOUNT_PATH=/runpod-volume
RUNPOD_DATA_CENTER_ID=
RUNPOD_DATA_CENTER_IDS=
RUNPOD_MIN_CUDA_VERSION=12.4
RUNPOD_PORTS=8000/http
RUNPOD_STOP_AFTER=4h

MO_PROVIDER_MODE=local
MO_ASR_PROVIDER=faster-whisper
MO_TRANSLATION_PROVIDER=qwen3
MO_TTS_PROVIDER=qwen-seed-vc
MO_PRELOAD_MODELS=1

MODEL_CACHE_DIR=/runpod-volume/models
HF_HOME=/runpod-volume/huggingface
HF_HUB_CACHE=/runpod-volume/huggingface/hub
FASTER_WHISPER_CACHE_DIR=/runpod-volume/models/faster-whisper
SEED_VC_WORK_DIR=/runpod-volume/work/seed-vc

FASTER_WHISPER_MODEL=mobiuslabsgmbh/faster-whisper-large-v3-turbo
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_LOCAL_FILES_ONLY=0

QWEN_TRANSLATION_MODEL=Qwen/Qwen3-4B
QWEN_TRANSLATION_DEVICE_MAP=auto
QWEN_TRANSLATION_DTYPE=auto
QWEN_TRANSLATION_LOCAL_FILES_ONLY=0

QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_TTS_DEVICE_MAP=auto
QWEN_TTS_DTYPE=float16

SEED_VC_FP16=true
SEED_VC_REFERENCE_MAX_SECONDS=10
SEED_VC_REFERENCE_SAMPLE_RATE=24000
SEED_VC_REFERENCE_PREPARE_TIMEOUT_SECONDS=90
SEED_VC_DIFFUSION_STEPS=30
SEED_VC_LENGTH_ADJUST=1.0
SEED_VC_INFERENCE_CFG_RATE=0.7

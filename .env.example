# Copy this file to .env for local development.
#
# Do not commit .env. API keys and tokens must stay outside git.

# OpenAI API backendを使う場合だけ設定する。
# OPENAI_API_KEY=
OPENAI_ASR_MODEL=gpt-4o-transcribe
OPENAI_TRANSLATION_MODEL=gpt-5.6-terra
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=wav
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSLATION_SAMPLE_RATE=24000
OPENAI_REALTIME_TRANSLATION_TIMEOUT_SECONDS=90

# テキスト読み上げのGoogle Translate web endpointは非公式用途。
GOOGLE_TTS_TIMEOUT_SECONDS=30

# Seed-VCを使う場合は、seed_vcをimportできる専用venvのPythonを指定する。
SEED_VC_PYTHON=tmp/voice-venv/bin/python

# Qwen/local providerを使う場合だけ有効化する。
# MO_PROVIDER_MODE=local
# MO_TTS_PROVIDER=qwen-seed-vc

# URL参照音声は既定でlocalhost/loopback接続だけ許可する。
# 非loopback環境で管理者の事前素材作成として明示許可する場合だけ1にする。
# 公開環境で明示禁止する場合は0にする。
# MO_VIBEVOICE_URL_REFERENCE_ENABLED=0

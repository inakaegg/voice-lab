{
  "name": "mo-speech",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config apps/web/vite.config.ts",
    "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "node --test tests/*.mjs",
    "test:worker": "node --test tests/*.mjs",
    "check:js": "node --check cloudflare/worker.mjs && node --check src/mo_speech/web/*.js",
    "check:web": "npm run typecheck:web && npm run build:web"
  },
  "dependencies": {
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
